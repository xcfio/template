{
    "name": "@cnpx/cnpx",
    "version": "0.0.4",
    "description": "A simple CLI to scaffold projects from remote templates",
    "author": "xcfio",
    "homepage": "https://github.com/xcfio/template/tree/main/cnpx/cnpx#readme",
    "type": "commonjs",
    "license": "MIT",
    "main": "./out/index.js",
    "module": "./out/index.mjs",
    "bin": {
        "cnpx": "./out/bin.js"
    },
    "exports": {
        ".": {
            "import": "./out/index.mjs",
            "require": "./out/index.js"
        }
    },
    "scripts": {
        "fmt": "prettier --config=.prettierrc --write src",
        "lint": "prettier --config=.prettierrc --check src",
        "build": "tsup",
        "dev": "tsup --watch",
        "test": "tsc --noEmit"
    },
    "keywords": [
        "cnpx",
        "create"
    ],
    "repository": {
        "type": "git",
        "url": "https://github.com/xcfio/template"
    },
    "bugs": {
        "url": "https://github.com/xcfio/template/issues",
        "email": "omarfaruksxp@gmail.com"
    },
    "funding": {
        "type": "patreon",
        "url": "https://www.patreon.com/xcfio"
    },
    "publishConfig": {
        "access": "public",
        "tag": "latest"
    },
    "dependencies": {
        "@clack/prompts": "^1.2.0",
        "colorette": "^2.0.20",
        "degit": "^2.8.4"
    },
    "devDependencies": {
        "@types/degit": "^2.8.6",
        "@types/node": "^25.5.2",
        "tsup": "^8.5.1"
    }
}
