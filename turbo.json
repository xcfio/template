{
    "$schema": "https://turborepo.com/schema.json",
    "ui": "tui",
    "tasks": {
        "build": {
            "dependsOn": ["^build"],
            "inputs": ["$TURBO_DEFAULT$", ".env*"],
            "outputs": [".next/**", "!.next/cache/**", "out/**"]
        },
        "test": {
            "dependsOn": ["^test"]
        },
        "publish": {
            "dependsOn": ["^publish"]
        },
        "dev": {
            "cache": false,
            "persistent": true
        }
    }
}
